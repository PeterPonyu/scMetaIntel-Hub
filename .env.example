# Optional Hugging Face mirror or endpoint
HF_ENDPOINT=https://hf-mirror.com

# Optional local Ollama host
OLLAMA_HOST=http://localhost:11434

# Runtime model defaults
SCMETA_LLM_MODEL=qwen2.5-1.5b
SCMETA_LLM_FAST_MODEL=qwen2.5-1.5b
SCMETA_EMBED_MODEL=mxbai-embed-large
SCMETA_BIO_EMBED_MODEL=biolord-2023
SCMETA_RERANK_MODEL=ms-marco-minilm-l6

# Runtime tuning
SCMETA_NUM_CTX=4096
SCMETA_DEVICE=cuda

# Optional cache/auth settings
HF_HUB_CACHE=
HF_TOKEN=
